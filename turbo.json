{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".output/**"],
      "env": ["VITE_CONVEX_URL", "VITE_CONVEX_SITE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:setup": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["convex/**/*.ts", "tests/**/*.ts"],
      "outputs": []
    },
    "test:e2e": {
      "cache": false
    }
  }
}
